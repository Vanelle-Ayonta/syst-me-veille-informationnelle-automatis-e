APP_NAME=Veille DIIF/BEAC
APP_SECRET_KEY=changez_cette_cle_en_production_avec_une_chaine_aleatoire_longue

DB_PATH=data/veille_diif.db

# LLM — choisir le provider : anthropic (défaut) ou openai
LLM_PROVIDER=anthropic

# Anthropic (utilisé si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=votre_cle_anthropic_ici
ANTHROPIC_MODEL_SMART=claude-sonnet-4-5
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# OpenAI (utilisé si LLM_PROVIDER=openai)
OPENAI_API_KEY=votre_cle_openai_ici
OPENAI_MODEL_SMART=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Reranker cross-encoder (étape 2b)
# Mettre USE_RERANKER=false pour désactiver (machine avec peu de RAM)
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
USE_RERANKER=true

# Mail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
MAIL_FROM=Veille DIIF/BEAC <votre_email@gmail.com>

# Collecte — fréquence par défaut en heures (168 = 1 semaine)
SCRAPING_INTERVAL_HOURS=168

# Chemins
UPLOADS_DIR=data/uploads
EXPORTS_DIR=data/exports
BACKUPS_DIR=data/backups
FAISS_INDEX_PATH=data/faiss_index
